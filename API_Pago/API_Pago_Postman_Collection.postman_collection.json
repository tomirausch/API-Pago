              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"idempotencyKey\": \"key-neg\",\n    \"amount\": -10.00,\n    \"currency\": \"USD\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/payments",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["payments"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 400\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /payments - Error: Campos faltantes",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"amount\": 100.00\n}"
            },
            "url": {
              "raw": "http://localhost:8080/payments",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["payments"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 400\", function () {",
