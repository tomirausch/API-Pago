                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Obtener Pago",
      "item": [
        {
          "name": "GET /payments/idempotency/{key} - Pago encontrado",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/payments/idempotency/key-123",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["payments", "idempotency", "key-123"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Response has payment data\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.idempotencyKey).to.eql('key-123');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /payments/idempotency/{key} - Pago no encontrado",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/payments/idempotency/nonexistent-key",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["payments", "idempotency", "nonexistent-key"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 404\", function () {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /payments/idempotency/{key} - Key vacía",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/payments/idempotency/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["payments", "idempotency", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 400 or 404\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([400, 404]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
