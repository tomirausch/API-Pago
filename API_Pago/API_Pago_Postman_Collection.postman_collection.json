{
  "info": {
    "name": "API Pago - Pruebas",
    "description": "Colección de pruebas para la API de Pagos desarrollada con Spring Boot",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "GET /health - Verificar estado de la aplicación",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Response body contains 'Ok'\", function () {",
                  "    pm.expect(pm.response.text()).to.eql('Ok');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Crear Pago",
      "item": [
        {
          "name": "POST /payments - Crear pago exitoso",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"idempotencyKey\": \"key-123\",\n    \"amount\": 100.50,\n    \"currency\": \"USD\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/payments",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["payments"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test(\"Response has required fields\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData).to.have.property('idempotencyKey');",
                  "    pm.expect(jsonData).to.have.property('amount');",
                  "    pm.expect(jsonData).to.have.property('currency');",
                  "    pm.expect(jsonData).to.have.property('status');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /payments - Error: IdempotencyKey duplicada",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"idempotencyKey\": \"key-123\",\n    \"amount\": 50.00,\n    \"currency\": \"EUR\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/payments",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["payments"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 400 or 409\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([400, 409]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /payments - Error: Amount negativo",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
