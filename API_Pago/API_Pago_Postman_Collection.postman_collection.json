    },
    {
      "name": "Test Payment",
      "item": [
        {
          "name": "POST /health/test-payment - Crear pago de prueba",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/health/test-payment",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["health", "test-payment"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Response has payment object\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('idempotencyKey');",
                  "    pm.expect(jsonData.idempotencyKey).to.eql('test-key');",
                  "});"
