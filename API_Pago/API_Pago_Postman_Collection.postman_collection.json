              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Response has correct idempotency key\", function () {",
                  "    pm.expect(pm.response.json().idempotencyKey).to.eql('idem-key-123');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /payments/idempotency/{key} - Pago no encontrado",
          "request": {
